<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>AltSchool Socialize - Feed</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/water.css@2/out/water.min.css">
</head>
<body>
    <h1>Latest Posts</h1>
    <hr>
    <% posts.forEach(post => { %>
        <article style="border: 1px solid #444; padding: 15px; margin-bottom: 20px; border-radius: 8px;">
            <h2><%= post.title %></h2>
            <p><%= post.content %></p>
            <small>By: <%= post.author ? post.author.username : 'Anonymous' %> | ❤️ <%= post.like_count %></small>
            <div>
                <% post.tags.forEach(tag => { %>
                    <span style="background: #333; padding: 2px 8px; border-radius: 4px; font-size: 0.8em;">#<%= tag %></span>
                <% }) %>
            </div>
        </article>
    <% }) %>
</body>
</html>