<%- include('partials/header') %>

<div class="container">
    <header class="page-header">
        <h1>My Profile</h1>
        <p class="subtitle">Manage your posts</p>
    </header>

    <div class="card">
        <h3>Create New Post</h3>
        <input type="text" id="postTitle" placeholder="Title">
        <textarea id="postContent" rows="3" placeholder="Content"></textarea>
        <input type="text" id="postTags" placeholder="Tags (comma separated)">
        <button onclick="createPost()" class="btn-primary">Save as Draft</button>
    </div>

    <div class="profile-section">
        <h2>📝 Drafts</h2>
        <div id="draftsList">
            <div class="loader">Loading drafts...</div>
        </div>
    </div>

    <div class="profile-section">
        <h2>✅ Published Posts</h2>
        <div id="publishedList">
            <div class="loader">Loading posts...</div>
        </div>
    </div>
</div>

<script>
    const token = localStorage.getItem('accessToken');
    
    if (!token) {
        window.location.href = '/login';
    }
    
    async function loadProfile() {
        try {
            const res = await fetch('/api/posts/my-posts', {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            const result = await res.json();
            
            if (res.ok && result.success) {
                const posts = result.data.posts || [];
                const drafts = posts.filter(p => p.state === 'draft');
                const published = posts.filter(p => p.state === 'published');
                
                const draftsList = document.getElementById('draftsList');
                if (drafts.length === 0) {
                    draftsList.innerHTML = '<p>No drafts yet. Create your first post above!</p>';
                } else {
                    let html = '';
                    for (let i = 0; i < drafts.length; i++) {
                        html += `
                            <div class="card">
                                <h4>${escapeHtml(drafts[i].title)}</h4>
                                <p>${escapeHtml(drafts[i].content.substring(0, 100))}...</p>
                                <button class="btn-primary" onclick="publishPost('${drafts[i]._id}')">Publish</button>
                                <button class="action-btn" onclick="deletePost('${drafts[i]._id}')">Delete</button>
                            </div>
                        `;
                    }
                    draftsList.innerHTML = html;
                }
                
                const publishedList = document.getElementById('publishedList');
                if (published.length === 0) {
                    publishedList.innerHTML = '<p>No published posts yet.</p>';
                } else {
                    let html = '';
                    for (let i = 0; i < published.length; i++) {
                        html += `
                            <div class="card">
                                <h4>${escapeHtml(published[i].title)}</h4>
                                <p>${escapeHtml(published[i].content.substring(0, 100))}...</p>
                                <small>❤️ ${published[i].like_count} likes</small>
                                <button class="action-btn" onclick="deletePost('${published[i]._id}')">Delete</button>
                            </div>
                        `;
                    }
                    publishedList.innerHTML = html;
                }
            } else {
                document.getElementById('draftsList').innerHTML = '<p>Error loading posts: ' + (result.message || 'Unknown error') + '</p>';
            }
        } catch(err) {
            console.error('Load profile error:', err);
            document.getElementById('draftsList').innerHTML = '<p>Error loading posts. Please check console.</p>';
        }
    }
    
    async function createPost() {
        const title = document.getElementById('postTitle').value;
        const content = document.getElementById('postContent').value;
        const tagsInput = document.getElementById('postTags').value;
        
        if (!title || !content) {
            alert('Please fill in title and content');
            return;
        }
        
        const tags = tagsInput ? tagsInput.split(',').map(t => t.trim()) : [];
        
        const btn = event.target;
        const originalText = btn.textContent;
        btn.textContent = 'Saving...';
        btn.disabled = true;
        
        try {
            const res = await fetch('/api/posts', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + token
                },
                body: JSON.stringify({ title, content, tags })
            });
            
            const result = await res.json();
            
            if (res.ok && result.success) {
                alert('✅ Draft saved successfully!');
                document.getElementById('postTitle').value = '';
                document.getElementById('postContent').value = '';
                document.getElementById('postTags').value = '';
                loadProfile();
            } else {
                alert('Error: ' + (result.message || 'Could not create post'));
            }
        } catch(err) {
            console.error('Create post error:', err);
            alert('Error creating post');
        } finally {
            btn.textContent = originalText;
            btn.disabled = false;
        }
    }
    
    async function publishPost(id) {
        if (!confirm('Publish this post? It will be visible to everyone.')) return;
        
        try {
            const res = await fetch('/api/posts/' + id + '/publish', {
                method: 'PATCH',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            
            if (res.ok) {
                alert('✅ Post published successfully!');
                loadProfile();
            } else {
                alert('Error publishing post');
            }
        } catch(err) {
            alert('Error publishing post');
        }
    }
    
    async function deletePost(id) {
        if (!confirm('Are you sure you want to delete this post?')) return;
        
        try {
            const res = await fetch('/api/posts/' + id, {
                method: 'DELETE',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            
            if (res.ok) {
                alert('✅ Post deleted successfully!');
                loadProfile();
            } else {
                alert('Error deleting post');
            }
        } catch(err) {
            alert('Error deleting post');
        }
    }
    
    function escapeHtml(text) {
        if (!text) return '';
        return text.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
    // Load profile when page loads
    loadProfile();
</script>

<%- include('partials/footer') %>